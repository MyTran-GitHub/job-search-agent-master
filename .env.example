# AgentFrame Consulting Prep — environment template.
# Copy to .env (gitignored) and fill only what you use. Everything is OPTIONAL — the system runs without it.
# (Your coding agent provides the LLM. These keys power the optional Composio connector tools.)

# --- Composio: one connection, 100+ tools (Google Docs, Gmail, Calendar, Drive, ...) ---
# OPTIONAL + manual: Composio is NOT wired in automatically. You connect it once per machine — its MCP URL is
# generated per-user, so it can't ship pre-configured. Full setup (SDK install, OAuth, claude mcp add) is in:
#   library/context/connectors.md
# Get an `ak_…` key from https://app.composio.dev, then follow that doc.
COMPOSIO_API_KEY=
USER_ID=

# --- TinyFish (primary job discovery for scrape command) ---
# Get your API key from https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=
TINYFISH_SEARCH_URL=https://api.search.tinyfish.ai
TINYFISH_FETCH_URL=https://api.fetch.tinyfish.ai
SCRAPE_MAX_POSTING_AGE_DAYS=10
SCRAPE_CONCURRENCY=3

# --- Job-search APIs (optional): broaden `find-job`'s cross-board discovery ---
# OPTIONAL. find-job works without any of these — it pulls from free public ATS feeds (Greenhouse/Lever/Ashby/
# Workday) and WebSearch. A key here only adds broad multi-board search. See library/context/connectors.md.
# JSearch (recommended): free tier ~200 req/mo. Subscribe on RapidAPI, then paste your RapidAPI key:
JSEARCH_RAPIDAPI_KEY=
# Apify (optional alternative): free plan ~$5 credits/mo, job-board + multi-ATS actors. Token from apify.com:
APIFY_API_TOKEN=
